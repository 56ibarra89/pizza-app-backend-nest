## PostgreSQL connection string (Prisma)
## Example:
## DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pizza_app?schema=public"
DATABASE_URL=

## Security
## In production, API_KEY is required unless REQUIRE_API_KEY is explicitly disabled.
API_KEY=

## Comma-separated list of allowed origins for CORS in production.
## Example: CORS_ORIGINS="https://my-frontend.com,https://admin.my-frontend.com"
CORS_ORIGINS=

## Enable Swagger (/docs) in production (default: disabled)
SWAGGER_ENABLED=false

## Force API key enforcement even outside production (default: false)
REQUIRE_API_KEY=false

## Configuración de Servidor de Correos (SMTP)
## Para Gmail: host=smtp.gmail.com, port=587, user=tu_correo, pass=contraseña_de_aplicación
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
