generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(uuid())
  username            String               @unique
  email               String?              @unique
  firstName           String
  lastName            String
  pin                 String               @unique
  passwordHash        String?
  role                UserRole
  isActive            Boolean              @default(true)
  failedLoginAttempts Int                  @default(0)
  lockoutLevel        Int                  @default(0)
  lockedUntil         DateTime?
  lastVisit           DateTime?
  themePreference     String               @default("light")
  tokenVersion        Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  createdAppConfigs   AppConfig[]          @relation("AppConfigCreatedBy")
  updatedAppConfigs   AppConfig[]          @relation("AppConfigUpdatedBy")
  createdCategories   Category[]           @relation("CategoryCreatedBy")
  updatedCategories   Category[]           @relation("CategoryUpdatedBy")
  createdCertificados Certificado[]        @relation("CertificadoCreatedBy")
  updatedCertificados Certificado[]        @relation("CertificadoUpdatedBy")
  createdCupones      Cupon[]              @relation("CuponCreatedBy")
  updatedCupones      Cupon[]              @relation("CuponUpdatedBy")
  createdDiscounts    DiscountPromotion[]  @relation("DiscountCreatedBy")
  updatedDiscounts    DiscountPromotion[]  @relation("DiscountUpdatedBy")
  createdHappyHours   HappyHourPromotion[] @relation("HappyHourCreatedBy")
  updatedHappyHours   HappyHourPromotion[] @relation("HappyHourUpdatedBy")
  cancelledOrders     Order[]              @relation("OrderCancelledBy")
  cashierOrders       Order[]              @relation("OrderCashier")
  payments            Payment[]
  createdProducts     Product[]            @relation("ProductCreatedBy")
  updatedProducts     Product[]            @relation("ProductUpdatedBy")
  cashierShifts       Shift[]              @relation("ShiftCashier")
  systemLogs          SystemLog[]          @relation("SystemLogUser")

  @@index([role])
  @@index([isActive])
}

model Customer {
  id        String            @id @default(uuid())
  name      String
  phone     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  addresses CustomerAddress[]
  orders    Order[]

  @@index([name])
  @@index([phone])
}

model CustomerAddress {
  id         String   @id @default(uuid())
  customerId String
  address    String
  lastUsed   DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, address])
  @@index([customerId])
  @@index([lastUsed])
}

model Mesa {
  id                String       @id @default(uuid())
  floor             Int
  estado            MesaEstado
  reservationName   String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  number            Int
  reservationAmount Decimal?     @db.Decimal(10, 2)
  expirationTime    DateTime?
  reservationTime   DateTime?
  linkedOrders      OrderTable[]

  @@unique([floor, number])
  @@index([floor])
  @@index([estado])
}

model Shift {
  id                       String      @id @default(uuid())
  startTime                DateTime
  endTime                  DateTime?
  openingAmount            Decimal     @db.Decimal(10, 2)
  closingAmount            Decimal?    @db.Decimal(10, 2)
  cashSales                Decimal     @default(0) @db.Decimal(12, 2)
  cardSales                Decimal     @default(0) @db.Decimal(12, 2)
  appSales                 Decimal     @default(0) @db.Decimal(12, 2)
  totalSales               Decimal     @default(0) @db.Decimal(12, 2)
  status                   ShiftStatus
  notes                    String?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
  cashierId                String?
  cashRegisterSnapshotName String?
  cashierSnapshotName      String
  orders                   Order[]
  cashier                  User?       @relation("ShiftCashier", fields: [cashierId], references: [id])

  @@index([cashierSnapshotName])
  @@index([cashRegisterSnapshotName])
  @@index([cashierId])
  @@index([startTime])
  @@index([status])
}

model Order {
  id                      String        @id @default(uuid())
  subTotal                Decimal?      @db.Decimal(12, 2)
  taxAmount               Decimal?      @db.Decimal(12, 2)
  total                   Decimal       @db.Decimal(12, 2)
  status                  OrderStatus
  timestamp               DateTime      @default(now())
  customerAddress         String?
  orderType               OrderType?
  isSentToKitchen         Boolean       @default(false)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  cashierId               String?
  customerId              String?
  shiftId                 String?
  invoiceCorrelativoId    String?
  invoiceDocumentType     DocumentType?
  invoiceResolutionNumber String?
  invoicePrefix           String?
  invoiceIssuedNumber     Int?
  invoiceNumber           String?       @unique
  invoiceIssuedAt         DateTime?
  discountAmount          Decimal?      @db.Decimal(12, 2)
  cancelReason            String?
  cancelledAt             DateTime?
  cancelledById           String?
  cashierSnapshotName     String?
  cuponId                 Int?
  customerSnapshotName    String?
  certificadosRedeemed    Certificado[]
  cancelledBy             User?         @relation("OrderCancelledBy", fields: [cancelledById], references: [id])
  cashier                 User?         @relation("OrderCashier", fields: [cashierId], references: [id])
  cupon                   Cupon?        @relation(fields: [cuponId], references: [id])
  customer                Customer?     @relation(fields: [customerId], references: [id])
  invoiceCorrelativo      Correlativo?  @relation("OrderInvoiceCorrelativo", fields: [invoiceCorrelativoId], references: [id])
  shift                   Shift?        @relation(fields: [shiftId], references: [id])
  items                   OrderItem[]
  linkedTables            OrderTable[]
  payments                Payment[]

  @@index([timestamp])
  @@index([shiftId])
  @@index([customerSnapshotName])
  @@index([customerId])
  @@index([status])
  @@index([cashierId])
  @@index([cuponId])
  @@index([invoiceCorrelativoId])
  @@index([invoiceIssuedAt])
  @@index([invoiceIssuedNumber])
}

/// Registro atómico de cada pago recibido en una orden.
/// Reemplaza los campos planos paymentMethod / splitEfectivo / splitTarjeta.
model Payment {
  id                  Int           @id @default(autoincrement())
  orderId             String
  method              PaymentMethod
  amount              Decimal       @db.Decimal(12, 2)
  /// Referencia externa (número de transacción, voucher, etc.)
  reference           String?
  cashierId           String?
  cashierSnapshotName String?
  createdAt           DateTime      @default(now())
  cashier             User?         @relation(fields: [cashierId], references: [id])
  order               Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([method])
}

model OrderTable {
  orderId   String
  tableId   String
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  mesa      Mesa     @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@id([orderId, tableId])
  @@index([tableId])
}

model OrderItem {
  id              Int              @id @default(autoincrement())
  orderId         String
  name            String
  price           Decimal          @db.Decimal(12, 2)
  size            ProductSize
  quantity        Int
  note            String?
  giftQuantity    Int              @default(0)
  isSentToKitchen Boolean          @default(false)
  sentAt          DateTime?
  kitchenStatus   KitchenStatus?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  productId       String?
  giftReason      String?
  order           Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product?         @relation(fields: [productId], references: [id])
  extras          OrderItemExtra[]

  @@index([orderId])
  @@index([productId])
  @@index([isSentToKitchen])
  @@index([kitchenStatus])
  @@index([sentAt])
}

model OrderItemExtra {
  id          Int       @id @default(autoincrement())
  orderItemId Int
  name        String
  price       Decimal   @db.Decimal(12, 2)
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
}

model Correlativo {
  id               String            @id @default(uuid())
  documentType     DocumentType
  resolutionNumber String
  prefix           String
  startNumber      Int
  endNumber        Int
  currentNumber    Int
  issueDate        DateTime
  expirationDate   DateTime
  status           CorrelativoStatus
  createdAt        DateTime          @default(now())
  invoiceOrders    Order[]           @relation("OrderInvoiceCorrelativo")

  @@index([documentType])
  @@index([status])
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  user      String
  role      String?
  action    String
  details   String?
  level     LogLevel @default(INFO)
  userId    String?
  userRef   User?    @relation("SystemLogUser", fields: [userId], references: [id])

  @@index([timestamp])
  @@index([userId])
  @@index([user])
  @@index([level])
}

model AppConfig {
  id          String   @id
  data        Json
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  createdBy   User?    @relation("AppConfigCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?    @relation("AppConfigUpdatedBy", fields: [updatedById], references: [id])

  @@index([createdById])
  @@index([updatedById])
}

model HappyHourPromotion {
  id             Int                    @id @default(autoincrement())
  name           String
  promotionType  HappyHourPromotionType
  status         PromoActiveStatus      @default(ACTIVO)
  /// Campo libre para tipo 2x1 (texto descriptivo del ítem)
  appliesTo      String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  deletedAt      DateTime?
  endMinutes     Int
  startMinutes   Int
  daysOfWeek     WeekDay[]
  /// Null cuando promotionType = DOSXUNO
  promotionValue Decimal?               @db.Decimal(10, 4)
  createdById    String?
  updatedById    String?
  categories     HappyHourCategory[]
  products       HappyHourProduct[]
  createdBy      User?                  @relation("HappyHourCreatedBy", fields: [createdById], references: [id])
  updatedBy      User?                  @relation("HappyHourUpdatedBy", fields: [updatedById], references: [id])

  @@index([status])
  @@index([deletedAt])
  @@index([createdById])
  @@index([updatedById])
}

/// Relación N:M entre HappyHour y productos específicos
model HappyHourProduct {
  happyHourId Int
  productId   String
  happyHour   HappyHourPromotion @relation(fields: [happyHourId], references: [id], onDelete: Cascade)
  product     Product            @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([happyHourId, productId])
  @@index([productId])
}

/// Relación N:M entre HappyHour y categorías completas
model HappyHourCategory {
  happyHourId Int
  categoryId  String
  category    Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  happyHour   HappyHourPromotion @relation(fields: [happyHourId], references: [id], onDelete: Cascade)

  @@id([happyHourId, categoryId])
  @@index([categoryId])
}

model DiscountPromotion {
  id            Int                @id @default(autoincrement())
  name          String
  discountType  CuponDiscountType
  status        PromoActiveStatus  @default(ACTIVO)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?
  discountValue Decimal            @db.Decimal(10, 4)
  createdById   String?
  updatedById   String?
  categories    DiscountCategory[]
  products      DiscountProduct[]
  createdBy     User?              @relation("DiscountCreatedBy", fields: [createdById], references: [id])
  updatedBy     User?              @relation("DiscountUpdatedBy", fields: [updatedById], references: [id])

  @@index([status])
  @@index([deletedAt])
  @@index([createdById])
  @@index([updatedById])
}

/// Relación N:M entre DiscountPromotion y productos específicos
model DiscountProduct {
  discountId Int
  productId  String
  discount   DiscountPromotion @relation(fields: [discountId], references: [id], onDelete: Cascade)
  product    Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([discountId, productId])
  @@index([productId])
}

/// Relación N:M entre DiscountPromotion y categorías completas
model DiscountCategory {
  discountId Int
  categoryId String
  category   Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  discount   DiscountPromotion @relation(fields: [discountId], references: [id], onDelete: Cascade)

  @@id([discountId, categoryId])
  @@index([categoryId])
}

model Cupon {
  id            Int               @id @default(autoincrement())
  code          String            @unique
  discountType  CuponDiscountType
  maxUses       Int               @default(0)
  currentUses   Int               @default(0)
  manualStatus  CuponManualStatus @default(ACTIVO)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?
  discountValue Decimal           @db.Decimal(10, 4)
  expiresDate   DateTime?
  createdById   String?
  updatedById   String?
  createdBy     User?             @relation("CuponCreatedBy", fields: [createdById], references: [id])
  updatedBy     User?             @relation("CuponUpdatedBy", fields: [updatedById], references: [id])
  orders        Order[]

  @@index([manualStatus])
  @@index([code])
  @@index([deletedAt])
  @@index([createdById])
  @@index([updatedById])
}

model Certificado {
  id              Int               @id @default(autoincrement())
  serial          String            @unique
  origin          String
  status          CertificadoStatus @default(DISPONIBLE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  amount          Decimal?          @db.Decimal(10, 2)
  deletedAt       DateTime?
  description     String?
  redeemedAt      DateTime?
  redeemedOrderId String?
  issueDate       DateTime
  createdById     String?
  updatedById     String?
  createdBy       User?             @relation("CertificadoCreatedBy", fields: [createdById], references: [id])
  redeemedOrder   Order?            @relation(fields: [redeemedOrderId], references: [id])
  updatedBy       User?             @relation("CertificadoUpdatedBy", fields: [updatedById], references: [id])
  items           CertificadoItem[]

  @@index([status])
  @@index([deletedAt])
  @@index([createdById])
  @@index([updatedById])
}

model CertificadoItem {
  id            Int         @id @default(autoincrement())
  certificadoId Int
  productId     String
  quantity      Int         @default(1)
  certificado   Certificado @relation(fields: [certificadoId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id])

  @@index([certificadoId])
  @@index([productId])
}

model Category {
  id          String              @id @default(uuid())
  label       String              @unique
  icon        String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  createdById String?
  deletedAt   DateTime?
  updatedById String?
  createdBy   User?               @relation("CategoryCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?               @relation("CategoryUpdatedBy", fields: [updatedById], references: [id])
  discounts   DiscountCategory[]
  happyHours  HappyHourCategory[]
  products    Product[]

  @@index([deletedAt])
  @@index([createdById])
  @@index([updatedById])
}

model Product {
  id               String             @id @default(uuid())
  categoryId       String
  name             String
  description      String?
  hasMultipleSizes Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  createdById      String?
  deletedAt        DateTime?
  updatedById      String?
  isActive         Boolean            @default(true)
  certificados     CertificadoItem[]
  discounts        DiscountProduct[]
  extras           ExtraIngredient[]
  happyHours       HappyHourProduct[]
  orderItems       OrderItem[]
  category         Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdBy        User?              @relation("ProductCreatedBy", fields: [createdById], references: [id])
  updatedBy        User?              @relation("ProductUpdatedBy", fields: [updatedById], references: [id])
  prices           ProductPrice[]

  @@unique([categoryId, name])
  @@index([deletedAt])
  @@index([createdById])
  @@index([updatedById])
}

model ProductPrice {
  id        String      @id @default(uuid())
  productId String
  size      ProductSize
  price     Decimal     @db.Decimal(10, 2)
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size])
}

model ExtraIngredient {
  id        String       @id @default(uuid())
  productId String
  name      String
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  prices    ExtraPrice[]

  @@unique([productId, name])
}

model ExtraPrice {
  id      String          @id @default(uuid())
  extraId String
  size    ProductSize
  price   Decimal         @db.Decimal(10, 2)
  extra   ExtraIngredient @relation(fields: [extraId], references: [id], onDelete: Cascade)

  @@unique([extraId, size])
}

enum ProductSize {
  FAMILIAR
  MEDIANA
  PERSONAL
  UNICO
}

enum UserRole {
  ADMIN
  CAJERO
  MESERO
  COCINERO
  MOTORIZADO
}

enum MesaEstado {
  DISPONIBLE
  RESERVADO
  OCUPADO
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
  PAID
  CANCELLED
}

enum KitchenStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
}

enum PaymentMethod {
  EFECTIVO
  TARJETA
  APP
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum OrderType {
  LOCAL
  LLEVAR
  DELIVERY
}

enum CorrelativoStatus {
  ACTIVO
  AGOTADO
  VENCIDO
}

enum DocumentType {
  FACTURA
}

enum PromoActiveStatus {
  ACTIVO
  INACTIVO
}

enum HappyHourPromotionType {
  DOSXUNO
  PORCENTAJE
  MONTO_FIJO
}

enum CuponDiscountType {
  PORCENTAJE
  MONTO_FIJO
}

enum CuponManualStatus {
  ACTIVO
  INACTIVO
}

enum CertificadoStatus {
  DISPONIBLE
  ENTREGADO
  ANULADO
}

enum LogLevel {
  INFO
  WARN
  ERROR
}
